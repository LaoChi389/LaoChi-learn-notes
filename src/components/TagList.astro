---
/**
 * 標籤小膠囊（Toon 風格）
 */
import { tagHref } from '../lib/notes';

interface Props {
  tags: string[];
  size?: 'sm' | 'md';
}

const { tags, size = 'sm' } = Astro.props;
const visible = tags.map((t) => t.trim()).filter(Boolean);
---

{
  visible.length > 0 && (
    <ul class:list={['flex flex-wrap gap-2', size === 'md' ? 'mt-4' : 'mt-2']} role="list">
      {visible.map((tag) => (
        <li>
          <a
            href={tagHref(tag)}
            class:list={[
              'toon-badge no-underline',
              size === 'md' ? 'px-3 py-1 text-sm' : '',
            ]}
          >
            #{tag}
          </a>
        </li>
      ))}
    </ul>
  )
}
