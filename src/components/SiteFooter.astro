---
/**
 * 全站頁尾
 * - 左：Logo
 * - 右：關於本人、搜尋、標籤
 * - 下：版權
 */
interface Props {
  logoSrc?: string;
}

const { logoSrc = '/logo.png' } = Astro.props;
const year = new Date().getFullYear();

const links = [
  { title: '關於本人', href: '/about' },
  { title: '搜尋', href: '/search' },
  { title: '標籤', href: '/tags' },
];
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-top">
      <a href="/" class="site-footer-brand" aria-label="回首頁">
        <img
          src={logoSrc}
          alt=""
          width="56"
          height="56"
          class="site-footer-logo"
          decoding="async"
        />
      </a>

      <nav class="site-footer-nav" aria-label="頁尾導覽">
        {
          links.map((link) => (
            <a href={link.href} class="site-footer-link">
              {link.title}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="site-footer-bottom">
      <p class="site-footer-copy">
        © {year} 紀錄學習的老紀LaoChi Notes. All rights reserved.
      </p>
    </div>
  </div>
</footer>
