---
/**
 * 全站共用版面 + SEO
 * - title 格式：頁面名 | 紀錄學習的老紀
 * - meta description、canonical、Open Graph
 */
import '../styles/global.css';
import SiteNav from '../components/SiteNav.svelte';
import SiteFooter from '../components/SiteFooter.astro';
import { getHeaderCategories } from '../lib/categories';

interface Props {
  /** 頁面標題（不含站名）；首頁請傳 isHome */
  title: string;
  description?: string;
  wide?: boolean;
  /** 首頁：title 只顯示站名 */
  isHome?: boolean;
  /** OG 類型 */
  ogType?: 'website' | 'article';
  /** 絕對或相對圖片路徑（預設用 logo） */
  image?: string;
  /** 文章發布時間（ISO，可選） */
  publishedTime?: string;
}

const siteName = '紀錄學習的老紀';
const defaultDescription =
  '我是老紀，原系統工程師，成了MEP工程師。這裡整理 AI、電氣電子、系統網路的學習筆記與實作紀錄。';

const {
  title,
  description = defaultDescription,
  wide = false,
  isHome = false,
  ogType = 'website',
  image,
  publishedTime,
} = Astro.props;

/** 標題：首頁 = 站名；其餘 = 名稱 | 站名 */
const pageTitle =
  isHome || title === '首頁' ? siteName : `${title} | ${siteName}`;

const pathname = Astro.url.pathname;
const site = Astro.site;
const canonicalURL = site
  ? new URL(pathname, site)
  : new URL(pathname, Astro.url.origin);

const ogImagePath = image ?? '/logo.png';
const ogImageURL = site
  ? new URL(ogImagePath, site).href
  : new URL(ogImagePath, Astro.url.origin).href;

const navItems = getHeaderCategories().map((c) => ({
  title: c.title,
  href: c.href,
  description: c.description,
}));
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />

    {/* 主題：避免閃爍，優先 localStorage，再系統偏好 */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme =
            stored === 'light' || stored === 'dark'
              ? stored
              : prefersDark
                ? 'dark'
                : 'light';
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>

    {/* 基本 SEO */}
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImageURL} />

    {/* Twitter / X 卡片 */}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {
      publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }

    <link rel="icon" type="image/png" href="/favicon-v2.png" />
    <link rel="apple-touch-icon" href="/favicon-v2.png" />
  </head>

  <body class="flex min-h-screen flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50
             focus:bg-accent focus:px-3 focus:py-2 focus:text-accent-foreground focus:no-underline"
    >
      跳到主要內容
    </a>

    <SiteNav
      client:load
      siteName={siteName}
      logoSrc="/logo.png"
      items={navItems}
      currentPath={pathname}
    />

    <main
      id="main-content"
      class:list={[
        'mx-auto w-full flex-1 px-4 pb-12 pt-6 sm:pb-16 sm:pt-8',
        wide ? 'max-w-5xl' : 'max-w-3xl',
      ]}
    >
      <slot />
    </main>

    <SiteFooter logoSrc="/logo.png" />
  </body>
</html>
