---
/**
 * 全站共用版面
 * - 頂部：TechCrunch 風格導覽（不含關於本人）
 * - 頁尾：Logo + 導覽連結（含關於本人）
 */
import '../styles/global.css';
import SiteNav from '../components/SiteNav.svelte';
import SiteFooter from '../components/SiteFooter.astro';
import { getHeaderCategories } from '../lib/categories';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const siteName = '紀錄學習的老紀';
const defaultDescription =
  '我是老紀，原系統工程師，成了MEP工程師，學習更多知識，以及鞏固分享以前的知識。';

const { title, description = defaultDescription, wide = false } = Astro.props;
const pageTitle = title === '首頁' ? siteName : `${title} · ${siteName}`;
const pathname = Astro.url.pathname;

/** 頂部導覽：只含 inHeader 的分類 */
const navItems = getHeaderCategories().map((c) => ({
  title: c.title,
  href: c.href,
  description: c.description,
}));
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/png" href="/favicon-v2.png" />
    <link rel="apple-touch-icon" href="/favicon-v2.png" />
    <title>{pageTitle}</title>
  </head>

  <body class="flex min-h-screen flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50
             focus:bg-accent focus:px-3 focus:py-2 focus:text-accent-foreground focus:no-underline"
    >
      跳到主要內容
    </a>

    <SiteNav
      client:load
      siteName={siteName}
      logoSrc="/logo.png"
      items={navItems}
      currentPath={pathname}
    />

    <main
      id="main-content"
      class:list={[
        'mx-auto w-full flex-1 px-4 pb-12 pt-6 sm:pb-16 sm:pt-8',
        wide ? 'max-w-5xl' : 'max-w-3xl',
      ]}
    >
      <slot />
    </main>

    <SiteFooter logoSrc="/logo.png" />
  </body>
</html>
