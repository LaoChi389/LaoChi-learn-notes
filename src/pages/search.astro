---
/**
 * 搜尋結果：與分類列表相同的條列風格
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildSearchIndex } from '../lib/notes';

const searchIndex = await buildSearchIndex();
const totalCount = searchIndex.length;
---

<BaseLayout title="搜尋" description="搜尋全部學習筆記">
  <nav class="breadcrumb" aria-label="麵包屑">
    <a href="/">首頁</a>
    <span class="mx-2 opacity-50">/</span>
    <span class="text-foreground">搜尋</span>
  </nav>

  <header class="page-header !pb-6 sm:!pb-8">
    <p class="section-label !mb-3">Search</p>
    <h1>搜尋</h1>
    <p class="mt-3 text-[0.975rem] text-muted-foreground">
      輸入關鍵字，搜尋標題、說明或標籤。
    </p>
  </header>

  <label class="sr-only" for="search-input">搜尋關鍵字</label>
  <input
    id="search-input"
    type="search"
    placeholder="例如：TEST、入門、網路…"
    autocomplete="off"
    class="search-input"
  />

  <p id="search-status" class="mt-3 text-sm text-muted-foreground" aria-live="polite">
    共 {totalCount} 篇筆記，輸入關鍵字開始搜尋。
  </p>

  <ul id="search-results" class="note-rows mt-6" role="list"></ul>

  <script define:vars={{ items: searchIndex }}>
    const input = document.getElementById('search-input');
    const status = document.getElementById('search-status');
    const list = document.getElementById('search-results');

    function escapeHtml(text) {
      return String(text)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;');
    }

    function matchItem(item, q) {
      const haystack = [
        item.title,
        item.description,
        item.categoryTitle,
        item.categoryId,
        ...item.tags,
      ]
        .join(' ')
        .toLowerCase();
      return haystack.includes(q);
    }

    function render(query) {
      if (!list || !status) return;

      const q = query.trim().toLowerCase();
      const filtered = q ? items.filter((item) => matchItem(item, q)) : items;

      if (q) {
        status.textContent =
          filtered.length === 0
            ? `找不到與「${query.trim()}」相關的筆記`
            : `找到 ${filtered.length} 篇與「${query.trim()}」相關的筆記`;
      } else {
        status.textContent = `共 ${items.length} 篇筆記，輸入關鍵字開始搜尋。`;
      }

      if (filtered.length === 0) {
        list.innerHTML = '';
        list.classList.add('is-empty');
        return;
      }

      list.classList.remove('is-empty');
      list.innerHTML = filtered
        .map((item) => {
          const desc = item.description
            ? `<p class="note-row-desc">${escapeHtml(item.description)}</p>`
            : '';
          return `
            <li>
              <article class="note-row-item">
                <a href="${escapeHtml(item.href)}" class="note-row-link">
                  <time class="note-row-date">${escapeHtml(item.date)}</time>
                  <div class="note-row-body">
                    <p class="note-row-meta">${escapeHtml(item.categoryTitle)}</p>
                    <h2 class="note-row-title">${escapeHtml(item.title)}</h2>
                    ${desc}
                  </div>
                </a>
              </article>
            </li>
          `;
        })
        .join('');
    }

    render('');

    const params = new URLSearchParams(window.location.search);
    const initial = params.get('q') ?? '';
    if (input) {
      input.value = initial;
      if (initial) render(initial);
      input.addEventListener('input', () => {
        render(input.value);
        const url = new URL(window.location.href);
        if (input.value.trim()) {
          url.searchParams.set('q', input.value.trim());
        } else {
          url.searchParams.delete('q');
        }
        history.replaceState(null, '', url);
      });
      input.focus();
    }
  </script>
</BaseLayout>
