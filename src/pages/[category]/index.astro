---
/**
 * 三大分類列表頁（Toon 卡片列表）
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotePreviewCard from '../../components/NotePreviewCard.svelte';
import { categories, getCategory, type CategoryId } from '../../lib/categories';
import { formatDate, noteHref } from '../../lib/notes';

export async function getStaticPaths() {
  // 「關於本人」改由 /about 單頁呈現，不走分類列表
  return categories
    .filter((cat) => cat.id !== 'about')
    .map((cat) => ({
      params: { category: cat.id },
    }));
}

const { category: categoryParam } = Astro.params;
const category = getCategory(categoryParam ?? '');

if (!category) {
  return Astro.redirect('/');
}

const categoryId = category.id as CategoryId;
const notes = (await getCollection(categoryId, ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const latestDate = notes[0] ? formatDate(notes[0].data.date) : null;
---

<BaseLayout
  title={category.title}
  description={`${category.title}相關學習筆記。${category.description}`}
>
  <nav class="breadcrumb" aria-label="麵包屑">
    <a href="/">首頁</a>
    <span class="mx-2 opacity-50">/</span>
    <span class="text-foreground">{category.title}</span>
  </nav>

  <header class="page-header toon-card toon-card--static">
    <p class="section-label !mb-3">Category</p>
    <h1>{category.title}</h1>
    <p class="mt-3 max-w-xl text-[0.975rem] leading-relaxed text-muted-foreground">
      {category.description}
    </p>
    <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-muted-foreground">
      <span class="toon-badge">{notes.length} 篇</span>
      {latestDate && <span>最近更新 {latestDate}</span>}
    </div>

    <nav class="category-switcher mt-6" aria-label="切換分類">
      {
        categories.map((cat) => (
          <a
            href={cat.href}
            class:list={['category-switcher-item', cat.id === category.id && 'is-active']}
            aria-current={cat.id === category.id ? 'page' : undefined}
          >
            {cat.title}
          </a>
        ))
      }
    </nav>
  </header>

  {
    notes.length === 0 ? (
      <p class="empty-state">
        這個分類還沒有筆記。在{' '}
        <code class="rounded-lg bg-muted px-1.5 py-0.5 text-sm">src/content/{category.id}/</code>{' '}
        新增 .md 檔即可。
      </p>
    ) : (
      <section aria-label={`${category.title}筆記列表`}>
        <ul class="bento-note-grid" role="list">
          {notes.map((note, i) => (
            <li class:list={[i === 0 && 'bento-note-featured']}>
              <NotePreviewCard
                href={noteHref(category.id, note.id)}
                title={note.data.title}
                description={note.data.description}
                dateLabel={formatDate(note.data.date)}
                dateIso={note.data.date.toISOString()}
                categoryLabel={category.title}
                featured={i === 0}
              />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <p class="mt-12 text-center text-sm">
    <a href="/" class="toon-btn toon-btn--ghost">← 回首頁</a>
  </p>
</BaseLayout>
