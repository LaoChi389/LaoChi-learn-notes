---
/**
 * 單篇筆記頁
 * - 清楚標題區（分類 / 日期 / 標籤）
 * - 目錄（TOC）快速跳轉
 * - 內文閱讀排版
 * - 上一篇 / 下一篇
 * - 返回分類列表
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import TagList from '../../components/TagList.astro';
import { categories, getCategory, type CategoryId } from '../../lib/categories';
import {
  formatDate,
  getNeighborNotes,
  noteHref,
  type NoteEntry,
} from '../../lib/notes';

export async function getStaticPaths() {
  const paths = [];

  for (const cat of categories) {
    // 關於本人使用 /about 單頁，不產生日誌式子頁
    if (cat.id === 'about') continue;
    const notes = await getCollection(cat.id, ({ data }) => !data.draft);
    for (const entry of notes) {
      paths.push({
        params: { category: cat.id, slug: entry.id },
        props: { entry: entry as NoteEntry },
      });
    }
  }

  return paths;
}

const { category: categoryParam } = Astro.params;
const { entry } = Astro.props;
const category = getCategory(categoryParam ?? '');

if (!category) {
  return Astro.redirect('/');
}

const categoryId = category.id as CategoryId;
const allNotes = (await getCollection(categoryId, ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
) as NoteEntry[];

// 依日期：newer = 較新，older = 較舊 → 對應 上一篇 / 下一篇
const { newer, older } = getNeighborNotes(allNotes, entry.id);
const { Content, headings } = await render(entry);

const hasToc = headings.some((h) => h.depth >= 2 && h.depth <= 3);
---

<BaseLayout
  title={entry.data.title}
  description={
    entry.data.description ??
    `${entry.data.title} — ${category.title}分類的學習筆記，來自紀錄學習的老紀。`
  }
  wide={hasToc}
  ogType="article"
  publishedTime={entry.data.date.toISOString()}
>
  {/* 麵包屑 */}
  <nav class="breadcrumb" aria-label="麵包屑">
    <a href="/">首頁</a>
    <span class="mx-2 opacity-50">/</span>
    <a href={category.href}>{category.title}</a>
    <span class="mx-2 opacity-50">/</span>
    <span class="text-foreground">{entry.data.title}</span>
  </nav>

  {/* ===== 標題區 ===== */}
  <header class="article-header toon-card toon-card--static">
    <div class="article-meta">
      <a href={category.href} class="article-category toon-badge">
        {category.title}
      </a>
      <time class="article-date" datetime={entry.data.date.toISOString()}>
        {formatDate(entry.data.date)}
      </time>
    </div>

    <h1 class="article-title">{entry.data.title}</h1>

    {
      entry.data.description && (
        <p class="article-desc">{entry.data.description}</p>
      )
    }

    {
      entry.data.tags.length > 0 && (
        <div class="article-tags">
          <TagList tags={entry.data.tags} size="md" />
        </div>
      )
    }
  </header>

  {/* ===== 正文 + 目錄 ===== */}
  <div class:list={['article-layout', hasToc && 'article-layout--with-toc']}>
    {
      hasToc && (
        <aside class="article-toc-aside">
          <TableOfContents headings={headings} />
        </aside>
      )
    }

    <div class="article-body toon-card toon-card--static article-body-card">
      <article class="app-prose">
        <Content />
      </article>
    </div>
  </div>

  {/* ===== 返回分類 ===== */}
  <p class="article-back">
    <a href={category.href} class="toon-btn toon-btn--ghost">
      ← 返回{category.title}列表
    </a>
  </p>

  {/* ===== 上一篇 / 下一篇 ===== */}
  <nav class="article-pager" aria-label="相鄰筆記">
    <div class="article-pager-item">
      {
        newer ? (
          <a href={noteHref(category.id, newer.id)} class="article-pager-link toon-card">
            <span class="article-pager-label">上一篇</span>
            <span class="article-pager-title">{newer.data.title}</span>
          </a>
        ) : (
          <span class="article-pager-empty" />
        )
      }
    </div>
    <div class="article-pager-item article-pager-item--next">
      {
        older ? (
          <a href={noteHref(category.id, older.id)} class="article-pager-link toon-card">
            <span class="article-pager-label">下一篇</span>
            <span class="article-pager-title">{older.data.title}</span>
          </a>
        ) : (
          <span class="article-pager-empty" />
        )
      }
    </div>
  </nav>
</BaseLayout>
