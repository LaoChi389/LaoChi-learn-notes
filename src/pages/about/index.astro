---
/**
 * 關於本人：單一完整頁（自我介紹 + 聯絡方式）
 * 內容來自 src/content/about/me.md
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/notes';

const entries = await getCollection('about', ({ data }) => !data.draft);
const entry =
  entries.find((e) => e.id === 'me') ??
  entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())[0];

if (!entry) {
  return Astro.redirect('/');
}

const { Content } = await render(entry);
---

<BaseLayout
  title="關於本人"
  description={entry.data.description ?? '自我介紹與聯絡方式'}
>
  <nav class="breadcrumb" aria-label="麵包屑">
    <a href="/">首頁</a>
    <span class="mx-2 opacity-50">/</span>
    <span class="text-foreground">關於本人</span>
  </nav>

  <article class="about-page toon-card toon-card--static">
    <header class="about-page-header">
      <p class="section-label !mb-2">About</p>
      <h1 class="about-page-title">{entry.data.title}</h1>
      {
        entry.data.description && (
          <p class="about-page-desc">{entry.data.description}</p>
        )
      }
      <time class="about-page-date" datetime={entry.data.date.toISOString()}>
        更新於 {formatDate(entry.data.date)}
      </time>
    </header>

    <div class="app-prose about-page-body">
      <Content />
    </div>
  </article>
</BaseLayout>
