---
/**
 * 首頁：Hero + 最新筆記
 * 三大分類改由右下／可拖動圓餅選單進入（見 CategoryPieMenu）
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NotePreviewCard from '../components/NotePreviewCard.svelte';
import { getCategory } from '../lib/categories';
import { formatDate, getAllNotes, noteHref } from '../lib/notes';

const LATEST_LIMIT = 20;

const allNotes = await getAllNotes();
const latestNotes = allNotes.slice(0, LATEST_LIMIT);
---

<BaseLayout title="首頁" wide>
  <div class="bento">
    {/* ===== Hero 介紹 ===== */}
    <header class="bento-hero toon-card toon-card--hero toon-card--static">
      <p class="section-label !mb-2 !text-[0.7rem]">Learning log</p>
      <h1 class="bento-hero-title">紀錄學習的老紀</h1>
      <p class="bento-hero-text">
        我是老紀，原系統工程師，成了MEP工程師，學習更多知識，以及鞏固分享以前的知識。
      </p>
      <div class="bento-hero-meta">
        <span class="toon-badge">共 {allNotes.length} 篇筆記</span>
        <a href="/search" class="toon-btn toon-btn--ghost">搜尋</a>
        <a href="/tags" class="toon-btn toon-btn--ghost">標籤</a>
      </div>
      <p class="bento-hero-hint">
        將滑鼠移到「分類」圓餅上即可展開三大分類；也可拖到喜歡的位置。
      </p>
    </header>

    {/* ===== 最新筆記 ===== */}
    <section class="bento-notes" aria-labelledby="latest-heading">
      <div class="bento-section-head">
        <div>
          <p class="section-label !mb-1">Recent</p>
          <h2 id="latest-heading" class="bento-section-title">最新筆記</h2>
        </div>
        <span class="text-sm text-muted-foreground">
          最近 {latestNotes.length} 篇
        </span>
      </div>

      {
        latestNotes.length === 0 ? (
          <p class="empty-state toon-card">
            還沒有筆記。到{' '}
            <code class="rounded-lg bg-muted px-1.5 py-0.5 text-sm">src/content/</code>{' '}
            新增 .md 即可。
          </p>
        ) : (
          <ul class="bento-note-grid" role="list">
            {latestNotes.map((note, i) => {
              const cat = getCategory(note.categoryId);
              return (
                <li class:list={[i === 0 && 'bento-note-featured']}>
                  <NotePreviewCard
                    href={noteHref(note.categoryId, note.id)}
                    title={note.data.title}
                    description={note.data.description}
                    dateLabel={formatDate(note.data.date)}
                    dateIso={note.data.date.toISOString()}
                    categoryLabel={cat?.title ?? note.categoryId}
                    featured={i === 0}
                  />
                </li>
              );
            })}
          </ul>
        )
      }
    </section>
  </div>
</BaseLayout>
