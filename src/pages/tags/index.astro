---
/**
 * 全部標籤總覽
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTags, tagHref } from '../../lib/notes';

const tags = await getAllTags();
---

<BaseLayout
  title="標籤"
  description="依標籤瀏覽紀錄學習的老紀的全部筆記，快速篩選主題。"
>
  <nav class="breadcrumb" aria-label="麵包屑">
    <a href="/">首頁</a>
    <span class="mx-2 opacity-50">/</span>
    <span class="text-foreground">標籤</span>
  </nav>

  <header class="page-header toon-card toon-card--static">
    <p class="section-label !mb-3">Tags</p>
    <h1>標籤</h1>
    <p class="mt-3 text-[0.975rem] text-muted-foreground">
      共 <span class="toon-badge">{tags.length}</span> 個標籤。點選可查看相關筆記。
    </p>
  </header>

  {
    tags.length === 0 ? (
      <p class="empty-state">
        還沒有任何標籤。在筆記 frontmatter 加上{' '}
        <code class="rounded-lg bg-muted px-1.5 py-0.5 text-sm">tags: [入門, 指令]</code> 即可。
      </p>
    ) : (
      <ul class="flex flex-wrap gap-2.5" role="list">
        {tags.map(({ tag, count }) => (
          <li>
            <a href={tagHref(tag)} class="tag-pill">
              <span>#{tag}</span>
              <span class="tabular-nums opacity-80">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
