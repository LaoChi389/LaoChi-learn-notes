---
/**
 * 標籤筆記列表（Toon 卡片）
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotePreviewCard from '../../components/NotePreviewCard.svelte';
import { getCategory } from '../../lib/categories';
import { formatDate, getAllTags, getNotesByTag, noteHref } from '../../lib/notes';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map(({ tag }) => ({
    params: { tag },
  }));
}

const rawTag = Astro.params.tag ?? '';
const tag = decodeURIComponent(rawTag);
const notes = await getNotesByTag(tag);
---

<BaseLayout
  title={`#${tag}`}
  description={`標籤「${tag}」的學習筆記列表 — 紀錄學習的老紀。`}
>
  <nav class="breadcrumb" aria-label="麵包屑">
    <a href="/">首頁</a>
    <span class="mx-2 opacity-50">/</span>
    <a href="/tags">標籤</a>
    <span class="mx-2 opacity-50">/</span>
    <span class="text-foreground">#{tag}</span>
  </nav>

  <header class="page-header toon-card toon-card--static">
    <p class="section-label !mb-3">Tag</p>
    <h1>#{tag}</h1>
    <p class="mt-3">
      <span class="toon-badge">{notes.length} 篇筆記</span>
    </p>
  </header>

  {
    notes.length === 0 ? (
      <p class="empty-state">這個標籤目前沒有筆記。</p>
    ) : (
      <ul class="bento-note-grid" role="list">
        {notes.map((note, i) => (
          <li class:list={[i === 0 && 'bento-note-featured']}>
            <NotePreviewCard
              href={noteHref(note.categoryId, note.id)}
              title={note.data.title}
              description={note.data.description}
              dateLabel={formatDate(note.data.date)}
              dateIso={note.data.date.toISOString()}
              categoryLabel={getCategory(note.categoryId)?.title ?? note.categoryId}
              featured={i === 0}
            />
          </li>
        ))}
      </ul>
    )
  }

  <p class="mt-10 text-center text-sm">
    <a href="/tags" class="toon-btn toon-btn--ghost">← 全部標籤</a>
  </p>
</BaseLayout>
